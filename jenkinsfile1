pipeline {
    agent any

    stages {
        stage('git-checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/moeed10/vagile-devsecops-p1-basic.git'
            }
        }

        stage('package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('tomcat-deploy') {
            steps {
                sh 'mvn tomcat7:deploy'
            }
        }
    }
}
